{
  "name": "Batta — Tunisia Real Estate Auctions",
  "short_name": "Batta",
  "description": "Tunisia's first dedicated real-estate auction platform. Transparency. Speed. Trust.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#FAF8F3",
  "theme_color": "#1F4E79",
  "lang": "ar",
  "dir": "rtl",
  "categories": ["finance", "business", "shopping"],
  "icons": [
    {
      "src": "/icons/icon.svg",
      "sizes": "any",

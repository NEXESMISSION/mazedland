# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cron (Vercel Cron). Vercel auto-sends this as `Authorization: Bearer`
# on scheduled invocations; the cron routes also accept it as `?key=`.
CRON_SECRET=

# Transactional email (Resend) — optional. Without BOTH of these the email
# worker (/api/cron/notify-email) is a silent no-op, so "you won / payment
# due / KYC verdict" stay in-app only. Set both + verify the sender domain in
# Resend to turn emails on. EMAIL_FROM must use a verified domain.
RESEND_API_KEY=
EMAIL_FROM="Batta.tn <no-reply@batta.tn>"

# Payments
# This app uses a manual receipt-upload flow only — buyers transfer
# funds externally (bank wire or D17 mobile-money push) and upload a
# receipt, then an admin verifies it under /admin/payments. No API
# gateway keys are needed. The admin-set payee details (RIB, IBAN,
# D17 number) live in `app_settings` (manage via /admin/legal-docs).

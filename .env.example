# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Payments
# This app uses a manual receipt-upload flow only — buyers transfer
# funds externally (bank wire or D17 mobile-money push) and upload a
# receipt, then an admin verifies it under /admin/payments. No API
# gateway keys are needed. The admin-set payee details (RIB, IBAN,
# D17 number) live in `app_settings` (manage via /admin/legal-docs).
